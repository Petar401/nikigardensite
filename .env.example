# Public access key for Web3Forms (https://web3forms.com) used by the contact form.
# It is a PUBLIC key (safe in the client bundle) but kept out of the repo so it can
# be rotated without a commit. Set the real value in .env.local locally and in the
# Vercel dashboard for production.
NEXT_PUBLIC_WEB3FORMS_KEY=

# Elfsight widget ID for the Google Reviews block on the homepage.
# Create the widget at https://elfsight.com/dashboard (connect the Google
# Business profile), then paste the widget ID (e.g. "abcd1234") here.
# Without this the homepage falls back to a clean "Read reviews on Google" link.
NEXT_PUBLIC_ELFSIGHT_REVIEWS_ID=
